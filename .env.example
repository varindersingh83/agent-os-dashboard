# === Model Configuration (OpenRouter) ===
# LiteLLM uses "openrouter/<model-name>" format
# Example: openrouter/google/gemini-2.0-flash-001 or openrouter/anthropic/claude-3-5-sonnet
OPENROUTER_API_KEY="your-openrouter-api-key"
LITELLM_MODEL="openrouter/google/gemini-2.0-flash-001"

# === Database Configuration ===
# For local Docker Compose, use the 'db' hostname
DATABASE_URL="postgresql://postgres:password@db:5432/agent_os"
QDRANT_URL="http://qdrant:6333"

# === NextAuth Configuration ===
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="H0AqLPsjgo835EKFRhZf7sLhqM4lSu0HsIcx1uF8Il4="

# === OAuth Providers (Optional) ===
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"
APPLE_ID="your-apple-id"
APPLE_TEAM_ID="your-apple-team-id"
APPLE_PRIVATE_KEY="your-apple-private-key"
APPLE_KEY_ID="your-apple-key-id"
FACEBOOK_CLIENT_ID="your-facebook-client-id"
FACEBOOK_CLIENT_SECRET="your-facebook-client-secret"

# === Connector Secrets (Optional) ===
SLACK_BOT_TOKEN="your-slack-bot-token"
GMAIL_ACCESS_TOKEN="your-gmail-access-token"
WHATSAPP_ACCESS_TOKEN="your-whatsapp-access-token"
WHATSAPP_PHONE_ID="your-whatsapp-phone-id"
