generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Organization {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  members     User[]
  vendors     VendorUser[]
  teams       Team[]
  leads       Lead[]
  assets      Asset[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

enum Role {
  OWNER
  ADMIN
  MEMBER
}

model User {
  id             String         @id @default(cuid())
  name           String?
  email          String         @unique
  emailVerified  DateTime?
  image          String?
  role           Role           @default(MEMBER)
  organizationId String
  organization   Organization   @relation(fields: [organizationId], references: [id])
  accounts       Account[]
  sessions       Session[]
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
}

model VendorUser {
  id             String         @id @default(cuid())
  name           String
  email          String         @unique
  organizationId String
  organization   Organization   @relation(fields: [organizationId], references: [id])
  scopedTeams    Team[]         @relation("VendorTeams")
  scopedAssets   Asset[]        @relation("VendorAssets")
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
}

model Team {
  id             String         @id @default(cuid())
  name           String
  description    String?
  organizationId String
  organization   Organization   @relation(fields: [organizationId], references: [id])
  agents         Agent[]
  vendorUsers    VendorUser[]   @relation("VendorTeams")
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
}

model Agent {
  id             String         @id @default(cuid())
  name           String
  role           String
  persona        String?        @db.Text
  teamId         String
  team           Team           @relation(fields: [teamId], references: [id])
  isFinancial    Boolean        @default(false)
  runs           AgentRun[]
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
}

model AgentRun {
  id             String         @id @default(cuid())
  agentId        String
  agent          Agent          @relation(fields: [agentId], references: [id])
  status         RunStatus      @default(PENDING)
  input          String?        @db.Text
  output         String?        @db.Text
  thoughtStream  String?        @db.Text
  tokenUsage     Int            @default(0)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
}

enum RunStatus {
  PENDING
  ACTIVE
  BLOCKED
  COMPLETED
  FAILED
}

model Lead {
  id             String         @id @default(cuid())
  name           String
  email          String?
  company        String?
  status         String         @default("NEW")
  organizationId String
  organization   Organization   @relation(fields: [organizationId], references: [id])
  source         String?
  notes          String?        @db.Text
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
}

model Asset {
  id               String         @id @default(cuid())
  name             String
  type             String         // e.g., 'PAGE', 'DOC', 'IMAGE'
  content          String?        @db.Text
  lineageSource    String?        // Ref to a specific Memory Chunk/Run ID
  organizationId   String
  organization     Organization   @relation(fields: [organizationId], references: [id])
  vendorUsers      VendorUser[]   @relation("VendorAssets")
  isPublic         Boolean        @default(false)
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
}

// NextAuth Next.js requirements
model Account {
  id                 String  @id @default(cuid())
  userId             String
  type               String
  provider           String
  providerAccountId  String
  refresh_token      String?  @db.Text
  access_token       String?  @db.Text
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String?  @db.Text
  session_state      String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}
