generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Organization {
  id               String         @id @default(cuid())
  name             String
  slug             String         @unique
  description      String?        @db.Text
  setupCompletedAt DateTime?
  members          User[]
  vendors          VendorUser[]
  teams            Team[]
  leads            Lead[]
  assets           Asset[]
  agents           Agent[]
  tasks            Task[]
  conversations    Conversation[]
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
}

enum Role {
  OWNER
  ADMIN
  MEMBER
}

model User {
  id             String         @id @default(cuid())
  name           String?
  email          String         @unique
  emailVerified  DateTime?
  image          String?
  role           Role           @default(MEMBER)
  organizationId String
  organization   Organization   @relation(fields: [organizationId], references: [id])
  accounts       Account[]
  sessions       Session[]
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
}

model VendorUser {
  id             String         @id @default(cuid())
  name           String
  email          String         @unique
  organizationId String
  organization   Organization   @relation(fields: [organizationId], references: [id])
  scopedTeams    Team[]         @relation("VendorTeams")
  scopedAssets   Asset[]        @relation("VendorAssets")
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
}

model Team {
  id             String         @id @default(cuid())
  name           String
  description    String?
  organizationId String
  organization   Organization   @relation(fields: [organizationId], references: [id])
  agents         Agent[]
  vendorUsers    VendorUser[]   @relation("VendorTeams")
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
}

model Agent {
  id               String         @id @default(cuid())
  name             String
  role             String
  goal             String?        @db.Text
  persona          String?        @db.Text
  organizationId   String
  organization     Organization   @relation(fields: [organizationId], references: [id])
  teamId           String?
  team             Team?          @relation(fields: [teamId], references: [id])
  parentAgentId    String?
  parentAgent      Agent?         @relation("AgentHierarchy", fields: [parentAgentId], references: [id])
  childAgents      Agent[]        @relation("AgentHierarchy")
  createdByUserId  String?
  createdByAgentId String?
  createdByType    String?        @default("USER")
  status           String         @default("ONLINE")
  isRoot           Boolean        @default(false)
  isFinancial      Boolean        @default(false)
  runs             AgentRun[]
  tasks            Task[]
  conversations    Conversation[]
  logEvents        AgentLogEvent[]
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
}

model AgentRun {
  id             String         @id @default(cuid())
  agentId        String
  agent          Agent          @relation(fields: [agentId], references: [id])
  status         RunStatus      @default(PENDING)
  input          String?        @db.Text
  output         String?        @db.Text
  thoughtStream  String?        @db.Text
  tokenUsage     Int            @default(0)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
}

enum RunStatus {
  PENDING
  ACTIVE
  BLOCKED
  COMPLETED
  FAILED
}

model Task {
  id             String      @id @default(cuid())
  title          String
  status         TaskStatus  @default(QUEUED)
  priority       TaskPriority @default(MEDIUM)
  summary        String?     @db.Text
  assignedAgentId String
  assignedAgent  Agent       @relation(fields: [assignedAgentId], references: [id])
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  startedAt      DateTime?
  completedAt    DateTime?
  tokenCost      Int         @default(0)
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
}

enum TaskStatus {
  QUEUED
  ACTIVE
  BLOCKED
  COMPLETED
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
}

model Conversation {
  id             String       @id @default(cuid())
  title          String
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  agentId        String
  agent          Agent        @relation(fields: [agentId], references: [id])
  messages       Message[]
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
}

model Message {
  id             String        @id @default(cuid())
  conversationId String
  conversation   Conversation  @relation(fields: [conversationId], references: [id])
  agentId        String
  role           MessageRole
  content        String        @db.Text
  createdAt      DateTime      @default(now())
}

enum MessageRole {
  user
  assistant
  system
}

model AgentLogEvent {
  id        String   @id @default(cuid())
  agentId   String
  agent     Agent    @relation(fields: [agentId], references: [id])
  type      String
  message   String   @db.Text
  createdAt DateTime @default(now())
}

model Lead {
  id             String         @id @default(cuid())
  name           String
  email          String?
  company        String?
  status         String         @default("NEW")
  organizationId String
  organization   Organization   @relation(fields: [organizationId], references: [id])
  source         String?
  notes          String?        @db.Text
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
}

model Asset {
  id               String         @id @default(cuid())
  name             String
  type             String         // e.g., 'PAGE', 'DOC', 'IMAGE'
  content          String?        @db.Text
  lineageSource    String?        // Ref to a specific Memory Chunk/Run ID
  organizationId   String
  organization     Organization   @relation(fields: [organizationId], references: [id])
  vendorUsers      VendorUser[]   @relation("VendorAssets")
  isPublic         Boolean        @default(false)
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
}

// NextAuth Next.js requirements
model Account {
  id                 String  @id @default(cuid())
  userId             String
  type               String
  provider           String
  providerAccountId  String
  refresh_token      String?  @db.Text
  access_token       String?  @db.Text
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String?  @db.Text
  session_state      String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}
